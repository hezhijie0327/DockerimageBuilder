From 99717266780378f0eb9a87125d2e594396ca53c9 Mon Sep 17 00:00:00 2001
From: "Ruben D." <ruben@winterrific.net>
Date: Mon, 16 Mar 2026 20:59:48 +0100
Subject: [PATCH 15/15] Set theme colors dynamically based on style preference

---
 searx/templates/simple/manifest.json |  4 ++--
 searx/webapp.py                      | 11 ++++++++++-
 2 files changed, 12 insertions(+), 3 deletions(-)

diff --git a/searx/templates/simple/manifest.json b/searx/templates/simple/manifest.json
index a7b2e7f669f..390e52022f5 100644
--- a/searx/templates/simple/manifest.json
+++ b/searx/templates/simple/manifest.json
@@ -19,7 +19,7 @@
     }
   ],
   "start_url": "{{ url_for('index') }}",
-  "theme_color": "#3050ff",
-  "background_color": "#fff",
+  "theme_color": "{{ theme_color }}" ,
+  "background_color": "{{ background_color }}",
   "display": "standalone"
 }
\ No newline at end of file
diff --git a/searx/webapp.py b/searx/webapp.py
index 9c322e69fba..019e1c85e42 100755
--- a/searx/webapp.py
+++ b/searx/webapp.py
@@ -1218,7 +1218,16 @@ def opensearch():
 
 @app.route('/manifest.json', methods=['GET'])
 def manifest():
-    ret = render('manifest.json')
+    if sxng_request.preferences.get_value('simple_style') == 'dark':
+        theme_color = "#58f"
+        background_color = "#222428"
+    elif sxng_request.preferences.get_value('simple_style') == 'black':
+        theme_color = "#3050ff"
+        background_color = "#000"
