From 3beb8b9376d2f83602273208742a4df5a72a7f36 Mon Sep 17 00:00:00 2001
From: "Ruben D." <ruben@winterrific.net>
Date: Mon, 16 Mar 2026 20:32:36 +0100
Subject: [PATCH 11/15] Generate manifest PWA icons with make resp. vite build
 command

---
 client/simple/tools/img.ts   | 31 +++++++++++++++++++++++++++++++
 client/simple/tools/plg.ts   | 18 +++++++++++++++++-
 client/simple/vite.config.ts | 12 +++++++++++-
 3 files changed, 59 insertions(+), 2 deletions(-)

diff --git a/client/simple/tools/img.ts b/client/simple/tools/img.ts
index 03add435f85..86529c59980 100644
--- a/client/simple/tools/img.ts
+++ b/client/simple/tools/img.ts
@@ -62,3 +62,34 @@ export const svg2svg = (items: Src2Dest[], svgo_opts: Config): void => {
     }
   }
 };
+
+/**
+ * Convert a SVG Icon to PWA Icons.
+ *
+ * @param item - SVG file (src: SVG-file, dest: folder) to convert.
+ * @param sizes - Array of numbers of square picture resolution.
+ */
+export const svg2pwa = (item: Src2Dest, sizes: number[]): void => {
+    fs.mkdirSync(path.dirname(item.dest), { recursive: true });
+
+  for (const size of sizes) {
+
+    sharp(item.src)
+      .png({
+        force: true,
+        compressionLevel: 9,
+        palette: true
+      })
+      .resize(size, size, {
+        fit: 'contain'
+      })
+      .toFile(item.dest + size + '.png')
+      .then((info) => {
+        console.log(`[svg2pwa] created ${item.dest} -- bytes: ${info.size}, w:${info.width}px,  h:${info.height}px`);
+      })
+      .catch((error) => {
+        console.error(`ERROR: ${item.dest} -- ${error}`);
+        throw error;
+      });
+  }
+};
diff --git a/client/simple/tools/plg.ts b/client/simple/tools/plg.ts
index b5ff6e8f6b5..595e0738023 100644
--- a/client/simple/tools/plg.ts
+++ b/client/simple/tools/plg.ts
@@ -11,7 +11,7 @@
 
 import type { Config } from "svgo";
 import type { Plugin } from "vite";
-import { type Src2Dest, svg2png, svg2svg } from "./img.ts";
+import { type Src2Dest, svg2png, svg2svg, svg2pwa } from "./img.ts";
 
 /**
  * Vite plugin to convert a list of SVG files to PNG.
@@ -43,3 +43,19 @@ export const plg_svg2svg = (items: Src2Dest[], svgo_opts: Config): Plugin => {
     }
   };
 };
+
+/**
+ * Vite plugin to optimize SVG images for PWA.
+ *
+ * @param item - Array of SVG files (src: SVG-file, dest: folder) to optimize.
+ * @param sizes - Output pixel size
+ */
+export const plg_svg2pwa = (item: Src2Dest, sizes: number[]): Plugin => {
+  return {
+    name: "searxng-simple-svg2svg",
+    apply: "build",
+    writeBundle: () => {
+      svg2pwa(item, sizes);
+    }
+  };
+};
diff --git a/client/simple/vite.config.ts b/client/simple/vite.config.ts
index 34cb6cdfd9e..008e55949f3 100644
--- a/client/simple/vite.config.ts
+++ b/client/simple/vite.config.ts
@@ -13,7 +13,7 @@ import type { Config } from "svgo";
 import type { UserConfig } from "vite";
 import analyzer from "vite-bundle-analyzer";
 import manifest from "./package.json" with { type: "json" };
-import { plg_svg2png, plg_svg2svg } from "./tools/plg.ts";
+import { plg_svg2png, plg_svg2svg, plg_svg2pwa } from "./tools/plg.ts";
 
 const ROOT = "../../"; // root of the git repository
 
@@ -132,6 +132,16 @@ export default {
       }
     ]),
 
+    // SearXNG PWA Icons (static)
+    plg_svg2pwa(
+      {
+        src: `${PATH.brand}/searxng-wordmark.svg`,
+        dest: `${PATH.dist}/img/`
+      },[
+        512, 192
+      ]
+    ),
+
     // -- svg
     plg_svg2svg(
       [

