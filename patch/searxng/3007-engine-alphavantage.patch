+# SPDX-License-Identifier: AGPL-3.0-or-later
+"""Alpha Vantage (Stock Symbols)"""
+
+import typing as t
+
+from urllib.parse import urlencode
+
+from searx.result_types import EngineResults
+
+if t.TYPE_CHECKING:
+    from searx.extended_types import SXNG_Response
+    from searx.search.processors import OnlineParams
+
+about = {
+    "website": "https://www.alphavantage.co/",
+    "wikidata_id": None,
+    "official_api_documentation": "https://www.alphavantage.co/documentation/",
+    "use_official_api": True,
+    "require_api_key": True,
+    "results": "JSON",
+}
+
+categories = ["finance"]
+paging = False
+
+base_url = "https://www.alphavantage.co/query"
+
+api_key = "unset"
+
+
+def setup(engine_settings: dict[str, t.Any]) -> bool:
+    key: str = engine_settings.get("api_key", "")
+    if key and key not in ("unset", "unknown", "..."):
+        return True
+    return False
+
+
+def request(query: str, params: "OnlineParams") -> None:
+
+    args: dict[str, str] = {
+        "function": "SYMBOL_SEARCH",
+        "keywords": query,
+        "apikey": api_key,
+    }
+
+    params["url"] = f"{base_url}?{urlencode(args)}"
+
+
+def response(resp: "SXNG_Response") -> EngineResults:
+    res = EngineResults()
+    json_data: dict[str, t.Any] = resp.json()
+
+    for match in json_data.get("bestMatches", []):
+        res.add(
+            res.types.MainResult(
+                url=f"https://finance.yahoo.com/quote/{match.get('1. symbol', '')}",
+                title=f"{match.get('2. name', '')} ({match.get('1. symbol', '')})",
+                content=f"{match.get('3. type', '')} | {match.get('4. region', '')} | Currency: {match.get('8. currency', '')}",
+                metadata=f"Market: {match.get('5. marketOpen', '')} - {match.get('6. marketClose', '')} | Timezone: {match.get('7. timezone', '')} | Match Score: {match.get('9. matchScore', '')}",
+            )
+        )
+
+    return res
