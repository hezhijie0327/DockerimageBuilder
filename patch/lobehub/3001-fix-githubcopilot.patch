+
+      await expect(
+        instance.chat({
+          messages: [{ content: 'hello', role: 'user' }],
+          model: 'gpt-5.1-codex-mini',
+        } as any),
+      ).rejects.toBeDefined();
+
+      expect(convertResponseInputsSpy).toHaveBeenCalledWith(expect.any(Array), {
+        forceImageBase64: true,
+        strictToolPairing: true,
+      });
+    });
