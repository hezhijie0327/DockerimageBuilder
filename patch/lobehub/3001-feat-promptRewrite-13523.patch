+    [editor],
+  );
+
+  return (
+    <PromptTransformAction mode={'text'} prompt={markdownContent} onPromptChange={onPromptChange} />
+  );
+});
+
+RewritePrompt.displayName = 'RewritePrompt';
+
+export default RewritePrompt;
