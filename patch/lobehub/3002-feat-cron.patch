diff --git a/src/app/(backend)/api/agent/cron/dispatch/route.ts b/src/app/(backend)/api/agent/cron/dispatch/route.ts
new file mode 100644
index 00000000000..f9249b1ef73
--- /dev/null
+++ b/src/app/(backend)/api/agent/cron/dispatch/route.ts
@@ -0,0 +1,147 @@
+import debug from 'debug';
+import { type NextRequest } from 'next/server';
+import { NextResponse } from 'next/server';
+import urlJoin from 'url-join';
+
+import { AgentCronJobModel } from '@/database/models/agentCronJob';
+import { type AgentCronJob } from '@/database/schemas/agentCronJob';
+import { getServerDB } from '@/database/server';
+import { appEnv } from '@/envs/app';
+import { qstashClient, verifyQStashSignature } from '@/libs/qstash';
+import { shouldDispatchCronJob } from '@/server/services/agentCron/scheduleMatcher';
+import { AiAgentService } from '@/server/services/aiAgent';
+
+const log = debug('api-route:agent:cron-dispatch');
+
+const verifyApiKey = (request: NextRequest): boolean => {
+  const cronSecret = process.env.CRON_SECRET;
+  const apiKey = process.env.AGENT_EXEC_API_KEY;
+  const expectedSecret = cronSecret || apiKey;
+
+  if (!expectedSecret) {
+    log('API key verification disabled (CRON_SECRET/AGENT_EXEC_API_KEY not configured)');
+    return false;
+  }
+
+  const authHeader = request.headers.get('Authorization');
+  if (!authHeader?.startsWith('Bearer ')) {
+    return false;
+  }
+
+  return authHeader.slice(7) === expectedSecret;
+};
+
+const buildAgentExecUrl = (): string => {
+  const baseUrl = appEnv.INTERNAL_APP_URL || appEnv.APP_URL;
+  return urlJoin(baseUrl, '/api/agent');
+};
+
+const triggerAgentByQStash = async (job: AgentCronJob): Promise<void> => {
+  const headers: Record<string, string> = {
+    'Content-Type': 'application/json',
+  };
+
+  if (process.env.AGENT_EXEC_API_KEY) {
+    headers.Authorization = `Bearer ${process.env.AGENT_EXEC_API_KEY}`;
+  }
+
+  await qstashClient.publishJSON({
+    body: {
+      agentId: job.agentId,
+      cronJobId: job.id,
+      prompt: job.content,
+      title: job.name || undefined,
+      trigger: 'cron',
+      userId: job.userId,
+    },
+    destination: buildAgentExecUrl(),
+    headers,
+    retries: 3,
+  });
+};
+
+const triggerAgentDirectly = async (
+  db: Awaited<ReturnType<typeof getServerDB>>,
+  job: AgentCronJob,
+): Promise<void> => {
+  const aiAgentService = new AiAgentService(db, job.userId);
+
+  await aiAgentService.execAgent({
+    agentId: job.agentId,
+    autoStart: true,
+    cronJobId: job.id,
+    prompt: job.content,
+    title: job.name || undefined,
+    trigger: 'cron',
+  });
+};
+
+export async function POST(request: NextRequest) {
+  const rawBody = await request.text();
+
+  const isValidQStash = await verifyQStashSignature(request, rawBody);
+  const isValidApiKey = verifyApiKey(request);
+
+  if (!isValidQStash && !isValidApiKey) {
+    return NextResponse.json(
+      { error: 'Unauthorized - Valid QStash signature or API key required' },
+      { status: 401 },
+    );
+  }
+
+  const db = await getServerDB();
+  const enabledJobs = await AgentCronJobModel.getEnabledJobs(db);
+
+  if (!enabledJobs.length) {
+    return NextResponse.json({
+      dispatched: 0,
+      message: 'No enabled cron jobs found',
+      scanned: 0,
+      skipped: 0,
+      success: true,
+    });
+  }
+
+  let dispatched = 0;
+  let skipped = 0;
+  const failed: Array<{ error: string; id: string }> = [];
+
+  const hasQStashSigningKeys =
+    !!process.env.QSTASH_CURRENT_SIGNING_KEY && !!process.env.QSTASH_NEXT_SIGNING_KEY;
+  const hasAgentExecApiKey = !!process.env.AGENT_EXEC_API_KEY;
+  const shouldUseQStash =
+    !!process.env.QSTASH_TOKEN && (hasAgentExecApiKey || hasQStashSigningKeys);
+
+  for (const job of enabledJobs) {
+    try {
+      if (!shouldDispatchCronJob(job)) {
+        skipped += 1;
+        continue;
+      }
+
+      if (shouldUseQStash) {
+        await triggerAgentByQStash(job);
+      } else {
+        await triggerAgentDirectly(db, job);
+      }
+
+      await AgentCronJobModel.updateExecutionStats(db, job.id);
+      dispatched += 1;
+    } catch (error) {
+      const errorMessage = error instanceof Error ? error.message : 'Unknown error';
+      failed.push({
+        error: errorMessage,
+        id: job.id,
+      });
+      console.error('[agent:cron:dispatch]', { error, jobId: job.id });
+    }
+  }
+
+  return NextResponse.json({
+    dispatched,
+    failed,
+    scanned: enabledJobs.length,
+    skipped,
+    success: failed.length === 0,
+  });
+}
diff --git a/src/app/(backend)/api/agent/cron/execute/route.ts b/src/app/(backend)/api/agent/cron/execute/route.ts
new file mode 100644
index 00000000000..f58dac7592d
--- /dev/null
+++ b/src/app/(backend)/api/agent/cron/execute/route.ts
@@ -0,0 +1,101 @@
+import debug from 'debug';
+import { type NextRequest } from 'next/server';
+import { NextResponse } from 'next/server';
+
+import { AgentCronJobModel } from '@/database/models/agentCronJob';
+import { getServerDB } from '@/database/server';
+import { verifyQStashSignature } from '@/libs/qstash';
+import {
+  deleteCronJobSchedule,
+  isQStashCronEnabled,
+} from '@/server/services/agentCron/qstashSchedule';
+import { shouldDispatchCronJob } from '@/server/services/agentCron/scheduleMatcher';
+import { AiAgentService } from '@/server/services/aiAgent';
+
+const log = debug('api-route:agent:cron-execute');
+
+const verifyApiKey = (request: NextRequest): boolean => {
+  const expectedSecret = process.env.CRON_SECRET || process.env.AGENT_EXEC_API_KEY;
+  if (!expectedSecret) {
+    return false;
+  }
+
+  const authHeader = request.headers.get('Authorization');
+  if (!authHeader?.startsWith('Bearer ')) {
+    return false;
+  }
+
+  return authHeader.slice(7) === expectedSecret;
+};
+
+export async function POST(request: NextRequest) {
+  if (!isQStashCronEnabled()) {
+    return NextResponse.json({ message: 'QStash cron feature is disabled', skipped: true });
+  }
+
+  const rawBody = await request.text();
+
+  const isValidQStash = await verifyQStashSignature(request, rawBody);
+  const isValidApiKey = verifyApiKey(request);
+
+  if (!isValidQStash && !isValidApiKey) {
+    return NextResponse.json(
+      { error: 'Unauthorized - Valid QStash signature or API key required' },
+      { status: 401 },
+    );
+  }
+
+  let payload: { jobId?: string };
+  try {
+    payload = rawBody ? (JSON.parse(rawBody) as { jobId?: string }) : {};
+  } catch {
+    return NextResponse.json({ error: 'Invalid JSON body' }, { status: 400 });
+  }
+
+  if (!payload.jobId) {
+    return NextResponse.json({ error: 'jobId is required' }, { status: 400 });
+  }
+
+  const db = await getServerDB();
+  const job = await AgentCronJobModel.findById(db, payload.jobId);
+
+  if (!job) {
+    return NextResponse.json({ message: 'Cron job not found', success: true });
+  }
+
+  if (!job.enabled) {
+    return NextResponse.json({ message: 'Cron job disabled', skipped: true, success: true });
+  }
+
+  if (job.remainingExecutions !== null && job.remainingExecutions <= 0) {
+    await deleteCronJobSchedule(job.id);
+
+    return NextResponse.json({ message: 'Cron job depleted', skipped: true, success: true });
+  }
+
+  if (!shouldDispatchCronJob(job)) {
+    return NextResponse.json({ message: 'Not due in current slot', skipped: true, success: true });
+  }
+
+  const aiAgentService = new AiAgentService(db, job.userId);
+  await aiAgentService.execAgent({
+    agentId: job.agentId,
+    autoStart: true,
+    cronJobId: job.id,
+    prompt: job.content,
+    title: job.name || undefined,
+    trigger: 'cron',
+  });
+
+  const updated = await AgentCronJobModel.updateExecutionStats(db, job.id);
+
+  if (updated && !updated.enabled) {
+    try {
+      await deleteCronJobSchedule(job.id);
+    } catch (error) {
+      log('Failed to delete depleted cron schedule for job %s: %O', job.id, error);
+    }
+  }
+
+  return NextResponse.json({ executed: true, success: true });
+}
