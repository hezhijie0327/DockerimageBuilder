new file mode 100644
index 00000000000..8d5eae1fc85
--- /dev/null
+++ b/src/app/(backend)/api/agent/cron/dispatch/route.ts
@@ -0,0 +1,126 @@
+import debug from 'debug';
+import { type NextRequest } from 'next/server';
+import { NextResponse } from 'next/server';
+import urlJoin from 'url-join';
+
+import { AgentCronJobModel } from '@/database/models/agentCronJob';
+import { type AgentCronJob } from '@/database/schemas/agentCronJob';
+import { getServerDB } from '@/database/server';
+import { appEnv } from '@/envs/app';
+import { qstashClient, verifyQStashSignature } from '@/libs/qstash';
+import { shouldDispatchCronJob } from '@/server/services/agentCron/scheduleMatcher';
+import { AiAgentService } from '@/server/services/aiAgent';
+
+const log = debug('api-route:agent:cron-dispatch');
+
+const buildAgentExecUrl = (): string => {
+  const baseUrl = appEnv.INTERNAL_APP_URL || appEnv.APP_URL;
+  return urlJoin(baseUrl, '/api/agent');
+};
+
+const triggerAgentByQStash = async (job: AgentCronJob): Promise<void> => {
+  const headers: Record<string, string> = {
+    'Content-Type': 'application/json',
+  };
+
+  if (process.env.VERCEL_AUTOMATION_BYPASS_SECRET) {
+    headers['x-vercel-protection-bypass'] = process.env.VERCEL_AUTOMATION_BYPASS_SECRET;
+  }
+
+  await qstashClient.publishJSON({
+    body: {
+      agentId: job.agentId,
+      cronJobId: job.id,
+      prompt: job.content,
+      title: job.name || undefined,
+      trigger: 'cron',
+      userId: job.userId,
+    },
+    destination: buildAgentExecUrl(),
+    headers,
+    retries: 3,
+  });
+};
+
+const triggerAgentDirectly = async (
+  db: Awaited<ReturnType<typeof getServerDB>>,
+  job: AgentCronJob,
+): Promise<void> => {
+  const aiAgentService = new AiAgentService(db, job.userId);
+
+  await aiAgentService.execAgent({
+    agentId: job.agentId,
+    autoStart: true,
+    cronJobId: job.id,
+    prompt: job.content,
+    title: job.name || undefined,
+    trigger: 'cron',
+  });
+};
+
+export async function POST(request: NextRequest) {
+  const rawBody = await request.text();
+
+  const isValidQStash = await verifyQStashSignature(request, rawBody);
+
+  if (!isValidQStash) {
+    return NextResponse.json(
+      { error: 'Unauthorized - Valid QStash signature required' },
+      { status: 401 },
+    );
+  }
+
+  const db = await getServerDB();
+  const enabledJobs = await AgentCronJobModel.getEnabledJobs(db);
+
+  if (!enabledJobs.length) {
+    return NextResponse.json({
+      dispatched: 0,
+      message: 'No enabled cron jobs found',
+      scanned: 0,
+      skipped: 0,
+      success: true,
+    });
+  }
+
+  let dispatched = 0;
+  let skipped = 0;
+  const failed: Array<{ error: string; id: string }> = [];
+
+  const hasQStashSigningKeys =
+    !!process.env.QSTASH_CURRENT_SIGNING_KEY && !!process.env.QSTASH_NEXT_SIGNING_KEY;
+  const shouldUseQStash = !!process.env.QSTASH_TOKEN && hasQStashSigningKeys;
+
+  for (const job of enabledJobs) {
+    try {
+      if (!shouldDispatchCronJob(job)) {
+        skipped += 1;
+        continue;
+      }
+
+      if (shouldUseQStash) {
+        await triggerAgentByQStash(job);
+      } else {
+        await triggerAgentDirectly(db, job);
+      }
+
+      await AgentCronJobModel.updateExecutionStats(db, job.id);
+      dispatched += 1;
+    } catch (error) {
+      const errorMessage = error instanceof Error ? error.message : 'Unknown error';
+      failed.push({
+        error: errorMessage,
+        id: job.id,
+      });
+      console.error('[agent:cron:dispatch]', { error, jobId: job.id });
+    }
+  }
+
+  return NextResponse.json({
+    dispatched,
+    failed,
+    scanned: enabledJobs.length,
+    skipped,
+    success: failed.length === 0,
+  });
+}
