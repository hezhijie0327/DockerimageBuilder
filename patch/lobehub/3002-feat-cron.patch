+import { describe, expect, it } from 'vitest';
+
+import { isCronPatternMatched, shouldDispatchCronJob } from './scheduleMatcher';
+
+describe('scheduleMatcher', () => {
+  describe('isCronPatternMatched', () => {
+    it('should match daily cron in UTC', () => {
+      const now = new Date('2026-04-05T09:00:00.000Z');
+
+      expect(isCronPatternMatched('0 9 * * *', now, 'UTC')).toBe(true);
+      expect(isCronPatternMatched('30 9 * * *', now, 'UTC')).toBe(false);
+    });
+
+    it('should match weekly cron with timezone', () => {
+      const now = new Date('2026-04-05T01:00:00.000Z');
+
+      // 2026-04-05 09:00 Asia/Shanghai is Sunday(0)
+      expect(isCronPatternMatched('0 9 * * 0', now, 'Asia/Shanghai')).toBe(true);
+      expect(isCronPatternMatched('0 9 * * 1', now, 'Asia/Shanghai')).toBe(false);
+    });
+
+    it('should support step format', () => {
+      const now = new Date('2026-04-05T10:30:00.000Z');
+
+      expect(isCronPatternMatched('*/30 * * * *', now, 'UTC')).toBe(true);
+      expect(isCronPatternMatched('*/45 * * * *', now, 'UTC')).toBe(false);
+    });
+  });
+
+  describe('shouldDispatchCronJob', () => {
+    it('should dispatch when never executed before', () => {
+      const now = new Date('2026-04-05T10:00:00.000Z');
+
+      expect(
+        shouldDispatchCronJob(
+          {
+            cronPattern: '0 10 * * *',
+            lastExecutedAt: null,
+            timezone: 'UTC',
+          },
+          now,
+        ),
+      ).toBe(true);
+    });
+
+    it('should skip when already executed in current slot', () => {
+      const now = new Date('2026-04-05T10:00:20.000Z');
+
+      expect(
+        shouldDispatchCronJob(
+          {
+            cronPattern: '0 10 * * *',
+            lastExecutedAt: new Date('2026-04-05T10:00:00.000Z'),
+            timezone: 'UTC',
+          },
+          now,
+        ),
+      ).toBe(false);
+    });
+
+    it('should dispatch in next slot', () => {
+      const now = new Date('2026-04-05T10:30:00.000Z');
+
+      expect(
+        shouldDispatchCronJob(
+          {
+            cronPattern: '30 * * * *',
+            lastExecutedAt: new Date('2026-04-05T10:00:00.000Z'),
+            timezone: 'UTC',
+          },
+          now,
+        ),
+      ).toBe(true);
+    });
+  });
+});
