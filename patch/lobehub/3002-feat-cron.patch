+import { appEnv } from '@/envs/app';
+import { qstashClient } from '@/libs/qstash';
+
+const JOB_TICK_CRON = '*/15 * * * *';
+const JOB_SCHEDULE_ID_PREFIX = 'cron-job';
+
+export const isQStashCronEnabled = (): boolean => {
+  return appEnv.enableQStashCron === true;
+};
+
+const getAuthorizationSecret = (): string | undefined => {
+  return process.env.CRON_SECRET || process.env.AGENT_EXEC_API_KEY;
+};
+
+const hasQStashSigningKeys = (): boolean => {
+  return !!process.env.QSTASH_CURRENT_SIGNING_KEY && !!process.env.QSTASH_NEXT_SIGNING_KEY;
+};
+
+export const isQStashCronSchedulingReady = (): boolean => {
+  if (!isQStashCronEnabled()) return false;
+  if (!process.env.QSTASH_TOKEN) return false;
+  return !!getAuthorizationSecret() || hasQStashSigningKeys();
+};
+
+export const assertQStashCronSchedulingReady = (): void => {
+  if (!isQStashCronEnabled()) {
+    throw new Error('QStash cron feature is disabled by ENABLE_QSTASH_CRON');
+  }
+
+  if (!process.env.QSTASH_TOKEN) {
+    throw new Error('QSTASH_TOKEN is required for per-job cron scheduling');
+  }
+
+  if (!getAuthorizationSecret() && !hasQStashSigningKeys()) {
+    throw new Error(
+      'Cron scheduling requires CRON_SECRET or AGENT_EXEC_API_KEY, or both QSTASH signing keys',
+    );
+  }
+};
+
+const buildExecuteUrl = (): string => {
+  const baseUrl = appEnv.INTERNAL_APP_URL || appEnv.APP_URL;
+
+  return new URL('/api/agent/cron/execute', baseUrl).toString();
+};
+
+export const getCronJobScheduleId = (jobId: string): string => {
+  return `${JOB_SCHEDULE_ID_PREFIX}-${jobId}`;
+};
+
+export const upsertCronJobSchedule = async (jobId: string): Promise<string> => {
+  assertQStashCronSchedulingReady();
+
+  const authorizationSecret = getAuthorizationSecret();
+  const headers: Record<string, string> = {
+    'Content-Type': 'application/json',
+  };
+
+  if (authorizationSecret) {
+    headers.Authorization = `Bearer ${authorizationSecret}`;
+  }
+
+  const response = await qstashClient.schedules.create({
+    body: JSON.stringify({ jobId }),
+    cron: JOB_TICK_CRON,
+    destination: buildExecuteUrl(),
+    headers,
+    method: 'POST',
+    retries: 3,
+    scheduleId: getCronJobScheduleId(jobId),
+  });
+
+  return response.scheduleId;
+};
+
+export const deleteCronJobSchedule = async (jobId: string): Promise<void> => {
+  if (!process.env.QSTASH_TOKEN) return;
+
+  const scheduleId = getCronJobScheduleId(jobId);
+  try {
+    await qstashClient.schedules.delete(scheduleId);
+  } catch (error) {
+    // Idempotent delete: ignore not-found schedule
+    const message = error instanceof Error ? error.message : String(error);
+    if (message.includes('404') || message.toLowerCase().includes('not found')) {
+      return;
+    }
+
+    throw error;
+  }
+};
