+++ b/src/server/services/agentCron/scheduleMatcher.ts
@@ -0,0 +1,118 @@
+import type { AgentCronJob } from '@/database/schemas/agentCronJob';
+
+type DateTimeParts = {
+  day: number;
+  hour: number;
+  minute: number;
+  month: number;
+  weekday: number;
+  year: number;
+};
+
+const weekdayMap: Record<string, number> = {
+  fri: 5,
+  mon: 1,
+  sat: 6,
+  sun: 0,
+  thu: 4,
+  tue: 2,
+  wed: 3,
+};
+
+const getDateTimeParts = (date: Date, timeZone: string): DateTimeParts => {
+  const formatter = new Intl.DateTimeFormat('en-US', {
+    day: 'numeric',
+    hour: 'numeric',
+    hour12: false,
+    minute: 'numeric',
+    month: 'numeric',
+    timeZone,
+    weekday: 'short',
+    year: 'numeric',
+  });
+
+  const parts = formatter.formatToParts(date);
+
+  const findPart = (type: Intl.DateTimeFormatPartTypes) =>
+    parts.find((part) => part.type === type)?.value;
+
+  const weekday = findPart('weekday')?.toLowerCase() || 'sun';
+
+  return {
+    day: Number(findPart('day') || 1),
+    hour: Number(findPart('hour') || 0),
+    minute: Number(findPart('minute') || 0),
+    month: Number(findPart('month') || 1),
+    weekday: weekdayMap[weekday] ?? 0,
+    year: Number(findPart('year') || 1970),
+  };
+};
+
+const matchToken = (token: string, value: number): boolean => {
+  const normalized = token.trim();
+  if (!normalized) return false;
+  if (normalized === '*') return true;
+
+  if (normalized.includes(',')) {
+    return normalized.split(',').some((item) => matchToken(item, value));
+  }
+
+  if (normalized.startsWith('*/')) {
+    const step = Number(normalized.slice(2));
+    if (!Number.isInteger(step) || step <= 0) return false;
+    return value % step === 0;
+  }
+
+  const numberValue = Number(normalized);
+  if (!Number.isInteger(numberValue)) return false;
+
+  return value === numberValue;
+};
+
+export const isCronPatternMatched = (
+  cronPattern: string,
+  date: Date,
+  timeZone: string,
+): boolean => {
+  const parts = cronPattern.trim().split(/\s+/);
+  if (parts.length !== 5) return false;
+
+  const [minutePart, hourPart, dayPart, monthPart, weekdayPart] = parts;
+  const local = getDateTimeParts(date, timeZone);
+
+  return (
+    matchToken(minutePart, local.minute) &&
+    matchToken(hourPart, local.hour) &&
+    matchToken(dayPart, local.day) &&
+    matchToken(monthPart, local.month) &&
+    matchToken(weekdayPart, local.weekday)
+  );
+};
+
+const getExecutionSlotKey = (date: Date, timeZone: string): string => {
+  const local = getDateTimeParts(date, timeZone);
+
+  return `${local.year}-${local.month}-${local.day}-${local.hour}-${local.minute}`;
+};
+
+export const shouldDispatchCronJob = (
+  job: Pick<AgentCronJob, 'cronPattern' | 'lastExecutedAt' | 'timezone'>,
+  now: Date = new Date(),
+): boolean => {
+  const timezone = job.timezone || 'UTC';
+
+  if (!isCronPatternMatched(job.cronPattern, now, timezone)) {
+    return false;
+  }
+
+  if (!job.lastExecutedAt) {
+    return true;
+  }
+
+  const lastRun = new Date(job.lastExecutedAt);
+  if (Number.isNaN(lastRun.getTime())) {
+    return true;
+  }
+
+  return getExecutionSlotKey(lastRun, timezone) !== getExecutionSlotKey(now, timezone);
+};
