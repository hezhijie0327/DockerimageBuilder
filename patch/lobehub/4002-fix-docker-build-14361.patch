 };
 
 const getTurbopackRoot = () => {
+  // During Docker builds the `next` package may be resolved from a different
+  // location (pnpm store or host paths). For Docker we prefer the project
+  // working directory so Turbopack can resolve `next/package.json` from the
+  // build context.
+  if (process.env.DOCKER === 'true') {
+    return realpathSync(process.cwd());
+  }
+
   const nextPackageDirectory = dirname(require.resolve('next/package.json'));
 
   return getCommonDirectory([realpathSync(process.cwd()), realpathSync(nextPackageDirectory)]);
