+import type { GenerateVideosConfig, GoogleGenAI } from '@google/genai';
+import debug from 'debug';
+
+import type { CreateVideoPayload, CreateVideoResponse } from '../../types/video';
+import { AgentRuntimeError } from '../../utils/createError';
+import { parseGoogleErrorMessage } from '../../utils/googleErrorParser';
+
+const log = debug('model-runtime:google:video');
+
+/**
+ * Create video using Google AI Veo models
+ * @see https://ai.google.dev/gemini-api/docs/video-generation
+ */
+export async function createGoogleVideo(
+  client: GoogleGenAI,
+  provider: string,
+  payload: CreateVideoPayload,
+): Promise<CreateVideoResponse> {
+  try {
+    const { model, params } = payload;
+    const { prompt, imageUrl, endImageUrl, aspectRatio, duration } = params;
+
+    log('Creating video with Google AI - model: %s, params: %O', model, params);
+
+    // Build video generation config
+    const config: GenerateVideosConfig = {
+      ...(aspectRatio && { aspectRatio }),
+    };
+
+    // Build request parameters
+    const requestParams: any = {
+      config,
+      model,
+      prompt,
+    };
+
+    // Add image-to-video support if imageUrl is provided
+    if (imageUrl) {
+      requestParams.image = imageUrl;
+    }
+
+    // Add last_frame if endImageUrl is provided
+    if (endImageUrl) {
+      requestParams.last_frame = endImageUrl;
+    }
+
+    // Add duration if specified
+    if (duration) {
+      requestParams.duration = `${duration}s`;
+    }
+
+    log('Google video generation request params: %O', requestParams);
+
+    // Start video generation
+    const operation = await client.models.generateVideos(requestParams);
+
+    log('Video generation started, operation name: %s', operation.operation?.name);
+
+    // Return operation name for polling
+    // Frontend will poll the operation status using async task polling mechanism
+    return { inferenceId: operation.operation?.name || '' };
+  } catch (error) {
+    const err = error as Error;
+    log('Error creating video with Google AI: %O', err);
+
+    if ((err as any)?.errorType) {
+      throw err;
+    }
+
+    const { errorType, error: parsedError } = parseGoogleErrorMessage(err.message);
+    throw AgentRuntimeError.createVideo({
+      error: parsedError,
+      errorType,
+      provider,
+    });
+  }
+}
+
+/**
+ * Poll video generation operation status
+ * @see https://ai.google.dev/gemini-api/docs/video-generation#polling
+ */
+export async function pollGoogleVideoOperation(
+  client: GoogleGenAI,
+  inferenceId: string,
+  provider: string,
+): Promise<
+  | { status: 'success'; videoUrl: string; apiKey: string }
+  | { status: 'failed'; error: string }
+  | { status: 'pending' }
+> {
+  try {
+    log('Polling video operation status: %s', inferenceId);
+
+    if (!inferenceId) {
+      return { error: 'Invalid operation name', status: 'failed' };
+    }
+
+    // Get operation status
+    const operation = await client.operations.getVideosOperation({
+      operation: { name: inferenceId },
+    });
+
+    log('Video operation status: %O', operation);
+
+    // Check if operation is complete
+    if (operation.done) {
+      // Check for errors
+      if (operation.error) {
+        return {
+          error: operation.error.message || 'Video generation failed',
+          status: 'failed',
+        };
+      }
+
+      // Extract video URL from response
+      const generatedVideos = operation.response?.generatedVideos;
+      if (!generatedVideos || generatedVideos.length === 0) {
+        return {
+          error: 'No video generated',
+          status: 'failed',
+        };
+      }
+
+      // Get the first video's download URI
+      const video = generatedVideos[0].video;
+      if (!video?.downloadUri) {
+        return {
+          error: 'No download URI found',
+          status: 'failed',
+        };
+      }
+
+      log('Video generation completed, download URI: %s', video.downloadUri);
+
+      // Return apiKey for authenticated download
+      // Download with: curl -L -o output.mp4 -H "x-goog-api-key: $GEMINI_API_KEY" "${videoUri}"
+      return {
+        headers: { 'x-goog-api-key': client.apiKey || '' },
+        status: 'success',
+        videoUrl: video.downloadUri,
+      };
+    }
+
+    // Operation still in progress
+    log('Video generation still in progress');
+    return { status: 'pending' };
+  } catch (error) {
+    const err = error as Error;
+    log('Error polling video operation: %O', err);
+
+    return {
+      error: err.message || 'Failed to poll video status',
+      status: 'failed',
+    };
+  }
+}
