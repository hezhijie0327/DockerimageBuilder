+++ b/packages/model-runtime/src/providers/minimax/video/handleCreateVideoWebhook.test.ts
@@ -0,0 +1,202 @@
+import { describe, expect, it } from 'vitest';
+
+import { handleMiniMaxVideoWebhook } from './handleCreateVideoWebhook';
+
+describe('handleMiniMaxVideoWebhook', () => {
+  const mockOptions = {
+    apiKey: 'test-key',
+    baseURL: 'https://api.minimaxi.com/v1',
+    provider: 'minimax',
+  };
+
+  describe('URL verification challenge', () => {
+    it('should return challenge string for URL verification', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            challenge: 'test-challenge-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toBe('test-challenge-123');
+    });
+  });
+
+  describe('intermediate statuses', () => {
+    it('should return pending for Processing status', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            status: 'Processing',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({ status: 'pending' });
+    });
+
+    it('should return pending for Preparing status', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            status: 'Preparing',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({ status: 'pending' });
+    });
+
+    it('should return pending for Queueing status', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            status: 'Queueing',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({ status: 'pending' });
+    });
+  });
+
+  describe('success', () => {
+    it('should return success result with videoUrl', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            base_resp: {
+              status_code: 0,
+              status_msg: 'Success',
+            },
+            duration: 6,
+            file_id: 'file-456',
+            status: 'Success',
+            task_id: 'task-123',
+            video_height: 1080,
+            video_width: 1920,
+            video_url: 'https://example.com/video.mp4',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({
+        inferenceId: 'task-123',
+        status: 'success',
+        videoUrl: 'https://example.com/video.mp4',
+      });
+    });
+
+    it('should throw when task_id is missing on success', async () => {
+      await expect(
+        handleMiniMaxVideoWebhook(
+          {
+            body: {
+              status: 'Success',
+              video_url: 'https://example.com/video.mp4',
+            },
+          },
+          mockOptions,
+        ),
+      ).rejects.toThrow('Missing task_id in webhook body');
+    });
+
+    it('should throw when video_url is missing on success', async () => {
+      await expect(
+        handleMiniMaxVideoWebhook(
+          {
+            body: {
+              status: 'Success',
+              task_id: 'task-123',
+            },
+          },
+          mockOptions,
+        ),
+      ).rejects.toThrow('Missing video_url in succeeded webhook body');
+    });
+  });
+
+  describe('error statuses', () => {
+    it('should return error from Fail status with message', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            base_resp: {
+              status_code: 1001,
+              status_msg: 'Content policy violation',
+            },
+            status: 'Fail',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({
+        error: 'Content policy violation',
+        inferenceId: 'task-123',
+        status: 'error',
+      });
+    });
+
+    it('should return default error message when base_resp is missing', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            status: 'Fail',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({
+        error: 'Video generation failed',
+        inferenceId: 'task-123',
+        status: 'error',
+      });
+    });
+
+    it('should throw when task_id is missing on failure', async () => {
+      await expect(
+        handleMiniMaxVideoWebhook(
+          {
+            body: {
+              status: 'Fail',
+            },
+          },
+          mockOptions,
+        ),
+      ).rejects.toThrow('Missing task_id in webhook body');
+    });
+  });
+
+  describe('unknown statuses', () => {
+    it('should return error for unknown status', async () => {
+      const result = await handleMiniMaxVideoWebhook(
+        {
+          body: {
+            status: 'UnknownStatus',
+            task_id: 'task-123',
+          },
+        },
+        mockOptions,
+      );
+
+      expect(result).toEqual({
+        error: 'Unknown status: UnknownStatus',
+        inferenceId: 'task-123',
+        status: 'error',
+      });
+    });
+  });
+});
