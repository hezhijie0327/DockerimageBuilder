+  imageUrl: { default: '' },
+  endImageUrl: { default: '' },
+  duration: { default: 5, min: 1, max: 10 },
+};
+
+const modelBSchema: VideoModelParamsSchema = {
+  prompt: { default: '' },
+  imageUrls: { default: [] },
+  imageUrl: { default: '' },
+  endImageUrl: { default: '' },
+  duration: { default: 3, min: 1, max: 10 },
+};
+
+const singleOnlySchema: VideoModelParamsSchema = {
+  prompt: { default: '' },
+  imageUrl: { default: '' },
+  endImageUrl: { default: '' },
+  duration: { default: 4, min: 1, max: 10 },
+};
+
+const multiOnlySchema: VideoModelParamsSchema = {
+  prompt: { default: '' },
+  imageUrls: { default: [] },
+  endImageUrl: { default: '' },
+  duration: { default: 4, min: 1, max: 10 },
+};
+
+const testVideoModels: AIVideoModelCard[] = [
+  {
+    id: 'video-model-a',
+    displayName: 'Video Model A',
+    type: 'video',
+    parameters: modelASchema,
+    releasedAt: '2025-01-01',
+  },
+  {
+    id: 'video-model-b',
+    displayName: 'Video Model B',
+    type: 'video',
+    parameters: modelBSchema,
+    releasedAt: '2025-01-02',
+  },
+  {
+    id: 'video-model-single-only',
+    displayName: 'Video Model Single Only',
+    type: 'video',
+    parameters: singleOnlySchema,
+    releasedAt: '2025-01-03',
+  },
+  {
+    id: 'video-model-multi-only',
+    displayName: 'Video Model Multi Only',
+    type: 'video',
+    parameters: multiOnlySchema,
+    releasedAt: '2025-01-04',
+  },
+];
+
+const mockProviders = [
+  {
+    id: 'provider-a',
+    name: 'Provider A',
+    children: [testVideoModels[0]],
+  },
+  {
+    id: 'provider-b',
+    name: 'Provider B',
+    children: [testVideoModels[1]],
+  },
+  {
+    id: 'provider-single-only',
+    name: 'Provider Single Only',
+    children: [testVideoModels[2]],
+  },
+  {
+    id: 'provider-multi-only',
+    name: 'Provider Multi Only',
+    children: [testVideoModels[3]],
+  },
+];
+
+vi.mock('@/store/aiInfra', () => ({
+  aiProviderSelectors: {
+    enabledVideoModelList: vi.fn(() => mockProviders),
+  },
+  getAiInfraStoreState: vi.fn(() => ({})),
+}));
+
+const modelBDefaultValues = extractVideoDefaultValues(modelBSchema);
+
+beforeEach(() => {
+  vi.clearAllMocks();
+
+  useVideoStore.setState({
+    isInit: true,
+    model: 'video-model-a',
+    provider: 'provider-a',
+    parametersSchema: modelASchema,
+    parameters: {
+      prompt: 'initial prompt',
+      imageUrl: 'start-frame.png',
+      endImageUrl: 'end-frame.png',
+      duration: 6,
+    } as RuntimeVideoGenParams,
+  });
+});
+
+afterEach(() => {
+  vi.restoreAllMocks();
+});
+
+describe('video generationConfig actions', () => {
+  it('should preserve prompt and frame images when switching model', () => {
+    const { result } = renderHook(() => useVideoStore());
+
+    act(() => {
+      result.current.setParamOnInput('prompt', 'cinematic sunset');
+      result.current.setParamOnInput('imageUrls', ['ref-1.png', 'ref-2.png']);
+      result.current.setParamOnInput('imageUrl', 'start-custom.png');
+      result.current.setParamOnInput('endImageUrl', 'end-custom.png');
+      result.current.setParamOnInput('duration', 8);
+    });
+
+    act(() => {
+      result.current.setModelAndProviderOnSelect('video-model-b', 'provider-b');
+    });
+
+    expect(result.current.parameters).toEqual({
+      ...modelBDefaultValues,
+      prompt: 'cinematic sunset',
+      imageUrls: ['ref-1.png', 'ref-2.png'],
+      imageUrl: 'start-custom.png',
+      endImageUrl: 'end-custom.png',
+    });
+    expect(result.current.parameters?.duration).toBe(modelBDefaultValues.duration);
+  });
+
+  it('should convert imageUrl to imageUrls when switching to multi-only model', () => {
+    const { result } = renderHook(() => useVideoStore());
+
+    act(() => {
+      result.current.setParamOnInput('prompt', 'single to multi');
+      result.current.setParamOnInput('imageUrl', 'single-ref.png');
+    });
+
+    act(() => {
+      result.current.setModelAndProviderOnSelect('video-model-multi-only', 'provider-multi-only');
+    });
+
+    expect(result.current.parameters?.imageUrls).toEqual(['single-ref.png']);
+    expect(result.current.parameters?.prompt).toBe('single to multi');
+  });
+
+  it('should convert first imageUrls item to imageUrl when switching to single-only model', () => {
+    const { result } = renderHook(() => useVideoStore());
+
+    useVideoStore.setState({
+      model: 'video-model-multi-only',
+      provider: 'provider-multi-only',
+      parametersSchema: multiOnlySchema,
+      parameters: {
+        prompt: 'multi to single',
+        imageUrls: ['multi-ref-1.png', 'multi-ref-2.png'],
+      } as RuntimeVideoGenParams,
+    });
+
+    act(() => {
+      result.current.setModelAndProviderOnSelect('video-model-single-only', 'provider-single-only');
+    });
+
+    expect(result.current.parameters?.imageUrl).toBe('multi-ref-1.png');
+    expect(result.current.parameters?.prompt).toBe('multi to single');
+  });
+});
